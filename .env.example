# ─────────────────────────────────────────────
# BuildRight & Associates — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────

# ── Server
NODE_ENV=development
PORT=4000

# ── PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=buildright_dev
DB_USER=postgres
DB_PASSWORD=your_password_here

# ── JWT Auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# ── File Storage (AWS S3 or compatible)
S3_BUCKET=buildright-documents
S3_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Email (for invoice sending & notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=invoices@buildright.gh

# ── Client (Vite — prefix with VITE_)
VITE_API_BASE_URL=http://localhost:4000/api/v1
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_anon_key_here
